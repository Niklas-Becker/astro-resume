{
  "compatibility_date": "2026-04-13",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "astro-theme-breeze",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
